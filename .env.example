# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# The following keys below are automatically created and
# added to your environment when you deploy on vercel

# Buoyant hiring proxy: auth token for https://hiring-proxy.trybuoyant.ai (sent as `x-api-key`)
ANTHROPIC_AUTH_TOKEN=****
# Optional: Anthropic-compatible base URL (must end with `/v1`; SDK appends `/messages`). Direct Anthropic: https://api.anthropic.com/v1
# AI_PROXY_BASE_URL=https://hiring-proxy.trybuoyant.ai/anthropic/v1

# Optional: xAI image generation (`small-model` in lib/ai/providers.ts)
XAI_API_KEY=****

# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/storage/vercel-postgres/quickstart
# Local: `docker compose up -d` then `pnpm db:migrate` — URL matches docker-compose.yml in this repo
POSTGRES_URL=****


# Resumable chat streams (`resumable-stream` uses the `redis` package; also accepts KV_URL).
# Local: start Redis with `docker compose up -d` (see docker-compose.yml), then:
REDIS_URL=redis://localhost:6379
# Hosted: https://vercel.com/docs/redis or any Redis provider that gives a rediss:// or redis:// URL
